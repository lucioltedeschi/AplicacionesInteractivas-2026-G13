<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Catalog"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#001220" />

        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Search by artist, era..."
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:paddingStart="15dp"
            android:background="@android:drawable/editbox_background"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The Chronos Legacy 1964"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#001220" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$42,500"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#001220"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="PLACE BID"
                    android:backgroundTint="#C5A059"
                    android:textColor="#001220"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ethereal Motion No. 7"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#001220" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$18,200"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#001220"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="VIEW DETAIL"
                    android:backgroundTint="#001220"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>