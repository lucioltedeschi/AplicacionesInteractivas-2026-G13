<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTituloHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mis participaciones"
            android:textColor="#0F172A"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescripcionHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Consultá tus pujas, subastas asistidas y resultados."
            android:textColor="#475569"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnActualizarHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:backgroundTint="#2563EB"
            android:text="Actualizar historial"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtMensajeHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Cargando historial..."
            android:textColor="#475569"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/contenedorHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnVolverHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="#E2E8F0"
            android:text="Volver"
            android:textColor="#0F172A"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>