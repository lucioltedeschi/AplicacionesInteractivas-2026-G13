<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTituloPuja"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Realizar puja"
            android:textColor="#0F172A"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDatosItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Cargando datos del ítem..."
            android:textColor="#475569"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Importe a ofertar"
                android:textColor="#0F172A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtImportePuja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="#F8FAFC"
                android:hint="Ej: 12100"
                android:inputType="numberDecimal"
                android:padding="14dp"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txtMensajePuja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text=""
                android:textAlignment="center"
                android:textColor="#DC2626"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnEnviarPuja"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:backgroundTint="#2563EB"
                android:text="Enviar puja"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btnVolverDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:backgroundTint="#E2E8F0"
            android:text="Volver"
            android:textColor="#0F172A"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>